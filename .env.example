# Optional — /assembly works without this: browser-only links to 국민참여입법센터 (no server XML calls).
# OC = 정보공개 신청 ID의 @ 앞부분 — same account family as data.go.kr / lawmaking.go.kr
# API guide: https://www.lawmaking.go.kr/api/apiGuideInfo?type=4-1
LAWMAKING_OC=

# Optional: default https://opinion.lawmaking.go.kr/rest/ogLmPp.xml
# LAWMAKING_REST_URL=

# Safest use of OC:
# - Put it only in .env.local (gitignored) or your host’s encrypted env UI.
# - Never NEXT_PUBLIC_* — keep server-only.
# - Never commit the raw value to git.

# /assembly data is cached 1h (unstable_cache). Refresh calls revalidateTag('assembly-monitor').
